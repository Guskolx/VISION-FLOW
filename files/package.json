{
  "name": "vision-flow",
  "version": "2.0.0",
  "description": "Transform your aspirations into reality with an interactive goal management platform that combines visual motivation, progress tracking, and AI coaching",
  "private": true,
  "author": "Guskolx",
  "license": "MIT",
  "homepage": "https://github.com/Guskolx/VISION-FLOW",
  "repository": {
    "type": "git",
    "url": "https://github.com/Guskolx/VISION-FLOW.git"
  },
  "bugs": {
    "url": "https://github.com/Guskolx/VISION-FLOW/issues"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.28"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/user-event": "^13.5.0",
    "jest": "^29.7.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.2",
    "prettier": "^3.0.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "dev": "npm start",
    "prod": "npm run build && npm start"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "goal-tracking",
    "productivity",
    "motivation",
    "dashboard",
    "saas",
    "react",
    "ai-coaching"
  ]
}
